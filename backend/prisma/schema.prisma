generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  projects Project[]
  created_at DateTime @default(now())
}

model Project {
  id Int @id @default(autoincrement())
  name String @unique
  tasks Task[]
  userId Int
  user User @relation(fields: [userId], references: [id])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  FINISHED
}

model Task {
  id Int @id @default(autoincrement())
  name String @unique
  projectId Int
  project Project @relation(fields: [projectId], references: [id])
  description String
  status TaskStatus @default(TODO)
}
